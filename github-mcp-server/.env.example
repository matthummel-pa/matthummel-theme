# Copy to .env (or set in your MCP client config) and fill in.
# Create a token at https://github.com/settings/tokens
#   - Fine-grained: grant Repository (Contents, Issues, Pull requests, Administration) + read on metadata
#   - Or classic: "repo" scope (and "read:user")
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Optional: override the API base URL for GitHub Enterprise Server
# GITHUB_API_URL=https://github.your-company.com/api/v3
