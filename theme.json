{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "760px", "wideSize": "1180px" },
    "color": {
      "defaultPalette": false,
      "custom": true,
      "palette": [
        { "slug": "paper", "color": "#fbfaf7", "name": "Paper" },
        { "slug": "surface", "color": "#ffffff", "name": "Surface" },
        { "slug": "ink", "color": "#17191e", "name": "Ink" },
        { "slug": "body", "color": "#2b2f36", "name": "Body" },
        { "slug": "muted", "color": "#5c636c", "name": "Muted" },
        { "slug": "green", "color": "#2f6b4e", "name": "Brand green" },
        { "slug": "green-tint", "color": "#eaf1ec", "name": "Green tint" },
        { "slug": "line", "color": "#e6e2d9", "name": "Line" }
      ]
    },
    "typography": {
      "fontFamilies": [
        { "slug": "display", "name": "Geist", "fontFamily": "\"Geist\", system-ui, sans-serif" },
        { "slug": "body", "name": "Inter", "fontFamily": "\"Inter\", system-ui, -apple-system, sans-serif" },
        { "slug": "mono", "name": "JetBrains Mono", "fontFamily": "\"JetBrains Mono\", Menlo, Consolas, monospace" }
      ],
      "fontSizes": [
        { "slug": "small", "size": "14px", "name": "Small" },
        { "slug": "medium", "size": "17px", "name": "Medium" },
        { "slug": "large", "size": "22px", "name": "Large" },
        { "slug": "x-large", "size": "32px", "name": "X-Large" },
        { "slug": "huge", "size": "clamp(40px, 6vw, 64px)", "name": "Huge" }
      ]
    }
  }
}
